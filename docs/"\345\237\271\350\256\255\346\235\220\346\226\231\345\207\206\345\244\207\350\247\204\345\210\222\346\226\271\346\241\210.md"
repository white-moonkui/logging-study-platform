## 技术实施方案

### 一、数据导入工具开发

#### 1.1 批量导入工具

```javascript
// scripts/batchImportMaterials.js

const Material = require('../models/TrainingMaterial');
const Case = require('../models/Case');
const Exam = require('../models/Exam');

async function batchImportMaterials(materials) {
    let stats = {
        knowledge: 0,
        cases: 0,
        exams: 0,
        errors: [],
    };

    for (const material of materials) {
        try {
            if (material.type === 'knowledge') {
                await importKnowledge(material);
                stats.knowledge++;
            } else if (material.type === 'case') {
                await importCase(material);
                stats.cases++;
            } else if (material.type === 'exam') {
                await importExam(material);
                stats.exams++;
            }
        } catch (error) {
            stats.errors.push({
                item: material.title,
                error: error.message,
            });
        }
    }

    return stats;
}
```

