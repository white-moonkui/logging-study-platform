### 三、自动化内容验证

#### 3.1 内容质量检查

```javascript
// utils/contentValidator.js

function validateKnowledge(knowledge) {
    const errors = [];

    if (!knowledge.title || knowledge.title.length < 5) {
        errors.push('标题至少5个字符');
    }

    if (!knowledge.content || knowledge.content.length < 100) {
        errors.push('内容至少100个字符');
    }

    if (!knowledge.keywords || knowledge.keywords.length < 3) {
        errors.push('至少3个关键词');
    }

    if (!knowledge.difficulty) {
        errors.push('必须指定难度等级');
    }

    return errors;
}
```

