## 后端实现

### models/category.js

```javascript
const dbAdapter = require('../utils/dbAdapter');
const mongoose = dbAdapter.getMongoose();

const categorySchema = new mongoose.Schema(
    {
        name: { type: String, required: true },
        code: { type: String, required: true, unique: true },
        parentId: { type: String, ref: 'Category' },
        level: { type: Number, required: true, default: 1 },
        sortOrder: { type: Number, default: 0 },
        icon: { type: String },
    },
    { timestamps: true }
);

module.exports = dbAdapter.getModel('Category', categorySchema);
```

### controllers/categoryController.js

```javascript
const Category = require('../models/category');
const { asyncHandler, requireRole } = require('../middleware/auth');

class CategoryController {
    // 获取分类树（递归查询）
    getTree = asyncHandler(async (req, res) => {
        const categories = await Category.find({}).sort({ sortOrder: 1 });
        const buildTree = (parentId = null) => {
            return categories
                .filter(c => String(c.parentId) === String(parentId))
                .map(c => ({
                    ...c.toObject(),
                    children: buildTree(c._id),
                }));
        };
        res.json({ data: buildTree(), success: true });
    });

    // 获取所有分类（扁平）
    getAll = asyncHandler(async (req, res) => {
        const categories = await Category.find({}).sort({ sortOrder: 1 });
        res.json({ data: categories, success: true });
    });

    // 创建分类（管理员）
    create = asyncHandler(async (req, res) => {
        const { name, code, parentId, sortOrder, icon } = req.body;

        // 验证父分类
        if (parentId) {
            const parent = await Category.findById(parentId);
            if (!parent) {
                return res.status(404).json({ message: '父分类不存在' });
            }
            req.body.level = parent.level + 1;
        }

        const category = await Category.create(req.body);
        res.json({ message: '创建成功', data: category });
    });

    // 更新分类（管理员）
    update = asyncHandler(async (req, res) => {
        const { name, sortOrder, icon } = req.body;
        const category = await Category.findByIdAndUpdate(
            req.params.id,
            { name, sortOrder, icon },
            { new: true }
        );
        res.json({ message: '更新成功', data: category });
    });

    // 删除分类（管理员）
    delete = asyncHandler(async (req, res) => {
        // 检查是否有子分类
        const childCount = await Category.countDocuments({ parentId: req.params.id });
        if (childCount > 0) {
            return res.status(400).json({ message: '该分类有子分类，无法删除' });
        }
        await Category.findByIdAndDelete(req.params.id);
        res.json({ message: '删除成功' });
    });
}

module.exports = new CategoryController();
```

### routes/categoryRoutes.js

```javascript
const express = require('express');
const router = express.Router();
const categoryController = require('../controllers/categoryController');
const { authenticateToken, requireRole } = require('../middleware/auth');

router.get('/tree', categoryController.getTree);
router.get('/', categoryController.getAll);

// 管理员权限
router.post(
    '/',
    authenticateToken,
    requireRole(['admin', 'instructor']),
    categoryController.create
);
router.put(
    '/:id',
    authenticateToken,
    requireRole(['admin', 'instructor']),
    categoryController.update
);
router.delete('/:id', authenticateToken, requireRole(['admin']), categoryController.delete);

module.exports = router;
```

