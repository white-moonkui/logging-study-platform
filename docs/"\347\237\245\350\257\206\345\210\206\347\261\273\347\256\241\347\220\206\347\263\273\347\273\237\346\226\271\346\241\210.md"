### 学习培训页面（动态加载）

```javascript
// public/learning.html
async function loadCategories() {
    try {
        const response = await fetch('http://localhost:3000/api/categories/tree');
        const data = await response.json();
        const categories = data.data;

        // 渲染分类树
        const container = document.getElementById('categories-container');
        container.innerHTML = categories.map(cat => createCategoryTree(cat)).join('');

        // 加载每个分类下的知识点
        loadKnowledgeByCategory(categories);
    } catch (error) {
        console.error('加载分类失败:', error);
    }
}

function createCategoryTree(category) {
    return `
    <div class="category-item ${category.children?.length ? 'has-children' : ''}">
      <div class="category-header" onclick="toggleCategory(this)">
        <i class="icon"></i>
        <span class="category-name">${category.name}</span>
        ${category.children?.length ? '<i class="chevron fa fa-chevron-right"></i>' : ''}
      </div>
      ${
          category.children?.length
              ? `
        <div class="category-children">
          ${category.children.map(child => createCategoryTree(child)).join('')}
        </div>
      `
              : ''
      }
    </div>
  `;
}
```

### 知识库管理页面（分类管理）

```javascript
// public/knowledge-management.html - 新增分类模块
async function showCategoryManager() {
    const response = await fetch('http://localhost:3000/api/categories/tree');
    const data = await response.json();

    document.getElementById('categoryManager').classList.add('show');

    // 树形编辑器
    const treeHtml = data.data.map(cat => renderCategoryTreeNode(cat)).join('');
    document.getElementById('categoryTree').innerHTML = treeHtml;
}

function renderCategoryTreeNode(category) {
    return `
    <div class="category-node">
      <input type="text" value="${category.name}" data-id="${category.id}" class="category-name-input">
      <button onclick="addCategory('${category.id}')">
        <i class="fa fa-plus"></i> 添加子分类
      </button>
      ${
          category.children?.length
              ? `
        <div class="category-children">
          ${category.children.map(child => renderCategoryTreeNode(child)).join('')}
        </div>
      `
              : ''
      }
    </div>
  `;
}

async function addCategory(parentId) {
    const name = prompt('请输入分类名称:');
    if (!name) return;

    const response = await fetch('http://localhost:3000/api/categories', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            name: name,
            parentId: parentId,
            code: name.toLowerCase().replace(/\s+/g, '_'),
            sortOrder: 0,
            icon: 'fa-folder',
        }),
    });

    if (response.ok) {
        showToast('分类添加成功');
        loadCategories(); // 刷新
    }
}
```

