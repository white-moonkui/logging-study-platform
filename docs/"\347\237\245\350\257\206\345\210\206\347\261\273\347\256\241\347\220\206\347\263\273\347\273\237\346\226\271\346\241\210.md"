## 数据库设计

### categories 表

```sql
CREATE TABLE categories (
  id         VARCHAR(36) PRIMARY KEY,
  name       VARCHAR(100) NOT NULL COMMENT '分类名称',
  code       VARCHAR(50) UNIQUE NOT NULL COMMENT '分类代码（用于前端显示）',
  parent_id  VARCHAR(36) NULL COMMENT '父分类ID',
  level      INT NOT NULL DEFAULT 1 COMMENT '层级: 1=根分类, 2=二级, 3=三级...',
  sort_order INT NOT NULL DEFAULT 0 COMMENT '排序序号',
  icon       VARCHAR(50) NULL COMMENT '图标类名',
  created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
  updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  INDEX idx_parent (parent_id),
  INDEX idx_level (level)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='知识分类表';
```

### knowledge_items 表

```sql
CREATE TABLE knowledge_items (
  id           VARCHAR(36) PRIMARY KEY,
  title        VARCHAR(200) NOT NULL COMMENT '标题',
  category_id  VARCHAR(36) NOT NULL COMMENT '分类ID',
  description  TEXT NULL COMMENT '描述',
  content      TEXT NULL COMMENT '详细内容',
  keywords     JSON NULL COMMENT '关键词数组',
  status       VARCHAR(20) NOT NULL DEFAULT 'draft' COMMENT 'published/draft/pending',
  created_by   VARCHAR(36) NULL COMMENT '创建者ID',
  created_at   DATETIME DEFAULT CURRENT_TIMESTAMP,
  updated_at   DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  FOREIGN KEY (category_id) REFERENCES categories(id) ON DELETE CASCADE,
  INDEX idx_category (category_id),
  INDEX idx_status (status)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='知识点表';
```

