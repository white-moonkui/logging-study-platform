### 3.4 统一数据结构

由于三个模块结构类似，统一使用以下数据模型：

#### 分类表 (ModuleCategory)

```javascript
{
  category_id: String,
  module: String,           // knowledge/case/exam
  category_name: String,
  parent_id: String,
  level: Number,           // 1/2/3/4
  order: Number,
  icon: String,
  description: String,

  // 扩展配置
  config: Object,          // 模块特定配置

  created_at: Date,
  updated_at: Date
}
```

#### 页面/内容表 (ModulePage)

```javascript
{
  page_id: String,
  module: String,          // knowledge/case/exam
  category_id: String,    // 所属分类

  // 页面信息
  page_name: String,
  page_type: String,     // content/exam/quiz

  // 内容/题目
  contents: [{
    content_id: String,
    content_type: String, // video/pdf/ppt/text/question
    title: String,
    file_url: String,
    // 考试专用
    question_type: String, // single/multi/judge/essay
    options: [String],
    answer: String,
    score: Number
  }],

  // 配置
  config: {
    time_limit: Number,     // 考试时间(分钟)
    passing_score: Number,   // 及格分数
    random_order: Boolean,   // 随机出题
    show_result: Boolean    // 立即显示成绩
  },

  // 统计
  view_count: Number,
  completion_count: Number,

  created_at: Date,
  updated_at: Date
}
```

