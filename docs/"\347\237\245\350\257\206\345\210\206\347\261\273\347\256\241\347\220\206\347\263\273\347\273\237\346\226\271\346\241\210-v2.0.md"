#### 数据库结构

```sql
CREATE TABLE knowledge_items (
  id                   VARCHAR(36) PRIMARY KEY,
  title                VARCHAR(200) NOT NULL,
  category_id          VARCHAR(36) NOT NULL,

  -- 基本信息字段
  description          TEXT NULL,
  content              TEXT NULL,
  keywords             JSON NULL,

  -- 元数据
  level                INT NOT NULL DEFAULT 1,
  sort_order           INT NOT NULL DEFAULT 0,
  status               VARCHAR(20) NOT NULL DEFAULT 'draft', -- published/draft/pending

  -- 多媒体支持
  video_cover          VARCHAR(255) NULL,     -- 视频封面图
  video_duration       INT NULL,              -- 视频时长（秒）

  -- 统计信息
  file_count           INT NOT NULL DEFAULT 0,
  video_count          INT NOT NULL DEFAULT 0,
  document_count       INT NOT NULL DEFAULT 0,
  presentation_count   INT NOT NULL DEFAULT 0,
  image_count          INT NOT NULL DEFAULT 0,

  -- 外部资源
  external_links       JSON NULL,             -- 外部链接（可选）

  created_by           VARCHAR(36) NULL,
  created_at           DATETIME DEFAULT CURRENT_TIMESTAMP,
  updated_at           DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,

  INDEX idx_category (category_id),
  INDEX idx_status (status),
  INDEX idx_sort (sort_order)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

CREATE TABLE knowledge_files (
  id                   VARCHAR(36) PRIMARY KEY,
  knowledge_id         VARCHAR(36) NOT NULL,
  file_type            ENUM('video', 'document', 'presentation', 'image', 'other') NOT NULL,

  -- 文件信息
  filename             VARCHAR(255) NOT NULL,
  original_name        VARCHAR(255) NOT NULL,
  file_path            VARCHAR(500) NOT NULL,  -- 相对路径
  file_size            BIGINT NOT NULL,        -- 字节
  mime_type            VARCHAR(100) NOT NULL,   -- MIME类型

  -- 视频专用
  duration             INT NULL,                -- 视频时长（秒）
  thumbnail            VARCHAR(255) NULL,       -- 缩略图路径

  -- 排序
  sort_order           INT NOT NULL DEFAULT 0,

  -- 上传信息
  uploaded_by          VARCHAR(36) NULL,
  uploaded_at          DATETIME DEFAULT CURRENT_TIMESTAMP,

  FOREIGN KEY (knowledge_id) REFERENCES knowledge_items(id) ON DELETE CASCADE,
  INDEX idx_knowledge (knowledge_id),
  INDEX idx_type (file_type),
  INDEX idx_sort (sort_order)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
```

