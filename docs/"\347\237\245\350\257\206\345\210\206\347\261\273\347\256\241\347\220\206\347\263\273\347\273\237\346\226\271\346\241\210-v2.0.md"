```javascript
// public/video-player.html
class VideoPlayer {
    constructor(containerId) {
        this.container = document.getElementById(containerId);
        this.currentFile = null;
        this.currentKnowledgeId = null;
    }

    // 播放视频
    play(videoFileId, knowledgeId) {
        const file = getFileInfo(videoFileId);
        this.currentFile = file;
        this.currentKnowledgeId = knowledgeId;

        this.container.innerHTML = `
      <div class="video-player-wrapper">
        <div class="video-player">
          <video id="mainVideo" controls preload="metadata">
            <source src="/uploads/knowledge/${knowledgeId}/videos/${file.filename}" type="${file.mimeType}">
            您的浏览器不支持视频播放
          </video>

          <div class="video-info-overlay">
            <h3>${file.filename}</h3>
            <p>${getKnowledgeTitle(knowledgeId)}</p>
            <div class="video-controls">
              <button onclick="skipBackward()">⏪ -10s</button>
              <button onclick="togglePlay()" id="playPauseBtn">
                <i class="fas fa-pause"></i> 暂停
              </button>
              <button onclick="skipForward()">+10s ⏩</button>
              <button onclick="closePlayer()">关闭</button>
            </div>
          </div>
        </div>

        <div class="playlist" id="playlist-${knowledgeId}">
          ${renderVideoPlaylist(knowledgeId)}
        </div>
      </div>
    `;

        const video = this.container.querySelector('video');
        video.addEventListener('timeupdate', () => this.updateProgress());
        video.addEventListener('ended', () => this.playNext());
    }

    // 播放下一个
    playNext() {
        const playlist = getVideoPlaylist(this.currentKnowledgeId);
        const currentIndex = playlist.findIndex(f => f.id === this.currentFile.id);

        if (currentIndex < playlist.length - 1) {
            const nextFile = playlist[currentIndex + 1];
            this.play(nextFile.id, this.currentKnowledgeId);
        } else {
            showToast('已经是最后一个视频了');
        }
    }

    // 播放上一个
    playPrevious() {
        const playlist = getVideoPlaylist(this.currentKnowledgeId);
        const currentIndex = playlist.findIndex(f => f.id === this.currentFile.id);

        if (currentIndex > 0) {
            const prevFile = playlist[currentIndex - 1];
            this.play(prevFile.id, this.currentKnowledgeId);
        } else {
            showToast('已经是第一个视频了');
        }
    }

    // 切换播放/暂停
    togglePlay() {
        const video = this.container.querySelector('video');
        const btn = this.container.querySelector('#playPauseBtn i');

        if (video.paused) {
            video.play();
            btn.className = 'fas fa-pause';
        } else {
            video.pause();
            btn.className = 'fas fa-play';
        }
    }

    // 关闭播放器
    closePlayer() {
        this.container.innerHTML = '';
    }
}

