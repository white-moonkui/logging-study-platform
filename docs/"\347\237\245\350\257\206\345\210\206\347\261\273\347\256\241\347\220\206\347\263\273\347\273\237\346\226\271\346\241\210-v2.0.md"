        sortOrder: { type: Number, default: 0 },
        uploadedBy: { type: String, ref: 'User' },
        uploadedAt: { type: Date, default: Date.now },
    },
    { timestamps: true }
);

module.exports = dbAdapter.getModel('KnowledgeFile', knowledgeFileSchema);
