// 文件排序逻辑
async function saveFileSort(knowledgeId, files) {
    // files: [{ fileId: 'xxx', sortOrder: 1 }, ...]

    const updates = files.map((file, index) => ({
        id: file.fileId,
        sortOrder: index,
    }));

    // 批量更新
    for (const update of updates) {
        await updateFileSortOrder(update.id, update.sortOrder);
