### KnowledgeController（新增文件管理）

```javascript
// controllers/knowledgeController.js

class KnowledgeController {
    // 获取知识点详情（包含所有文件）
    getDetails = asyncHandler(async (req, res) => {
        const { id } = req.params;

        const knowledge = await Knowledge.findById(id)
            .populate('categoryId', 'name code icon')
            .lean();

        if (!knowledge) {
            return res.status(404).json({ message: '知识点不存在' });
        }

        // 加载所有文件（按 sort_order 排序）
        const files = await KnowledgeFile.find({ knowledgeId: id })
            .sort({ sortOrder: 1, uploadedAt: 1 })
            .lean();

        // 按类型分组
        const filesByType = {
            video: files.filter(f => f.fileType === 'video'),
            document: files.filter(f => f.fileType === 'document'),
            presentation: files.filter(f => f.fileType === 'presentation'),
            image: files.filter(f => f.fileType === 'image'),
            other: files.filter(f => f.fileType === 'other'),
        };

        res.json({
            success: true,
            data: {
                ...knowledge,
                files: filesByType,
                fileCount: files.length,
                videoCount: filesByType.video.length,
                documentCount: filesByType.document.length,
                presentationCount: filesByType.presentation.length,
                imageCount: filesByType.image.length,
            },
        });
    });

    // 上传文件（支持多种类型）
    uploadFile = asyncHandler(async (req, res) => {
        const { knowledgeId } = req.params;
        const file = req.file;

        if (!file) {
            return res.status(400).json({ message: '请选择文件' });
        }

        // 根据文件扩展名确定类型
        const fileType = getFileTypeByExtension(file.originalname);

        // 计算视频时长（如果是视频）
        let duration = null;
        let thumbnail = null;

        if (fileType === 'video') {
            duration = await getVideoDuration(file.path);
            thumbnail = await generateVideoThumbnail(file.path);
        }

        // 生成文件信息
        const fileName = generateFileName(file.mimetype, fileType);
        const relativePath = `knowledge/${knowledgeId}/${fileType}s/${fileName}`;

        // 保存文件记录
        const fileRecord = await KnowledgeFile.create({
            knowledgeId,
            fileName: fileName,
            originalName: file.originalname,
            filePath: relativePath,
            fileSize: file.size,
            mimeType: file.mimetype,
            fileType,
            duration,
            thumbnail,
            uploadedBy: req.user.id,
        });

        res.json({
            message: '文件上传成功',
            data: {
                ...fileRecord.toObject(),
                type: fileType,
            },
        });
    });

    // 更新文件排序
    updateFileSort = asyncHandler(async (req, res) => {
        const { knowledgeId } = req.params;
        const { fileIds } = req.body; // [{ fileId: 'xxx', sortOrder: 1 }, ...]

        // 验证所有知识点ID匹配
        const knowledge = await Knowledge.findById(knowledgeId);
        if (!knowledge) {
            return res.status(404).json({ message: '知识点不存在' });
        }

        // 批量更新排序
        for (const { fileId, sortOrder } of fileIds) {
            await KnowledgeFile.findByIdAndUpdate(fileId, { sortOrder });
        }

        res.json({ message: '排序已更新' });
    });

    // 删除文件
    deleteFile = asyncHandler(async (req, res) => {
        const { knowledgeId, fileId } = req.params;

        // 验证
        const file = await KnowledgeFile.findOne({
            _id: fileId,
            knowledgeId,
        });

        if (!file) {
            return res.status(404).json({ message: '文件不存在' });
        }

        // 删除文件记录
        await KnowledgeFile.findByIdAndDelete(fileId);

        // 删除物理文件
        fs.unlinkSync(path.join(__dirname, '..', file.filePath));

        res.json({ message: '文件已删除' });
    });
}
