## 四、石化通交互流程（逐步骤实现）

### Step 1: 构建推送消息

```javascript
async function buildDailyMessage(userId) {
    const dueItems = await studyReminderService.getDueReviews(userId, 3);
    if (dueItems.length === 0) return null; // 无待复习

    const first = dueItems[0];
    const quiz = await generateQuiz(first.knowledgeId); // 复用现有 generate-quiz

    return `【测井培训 · 今日复习】📚\n\n` +
           `知识点: ${first.knowledgeId.title}\n` +
           `──────────────────\n` +
           `Q: ${quiz.question}\n` +
           quiz.options.map((opt, i) => `   ${String.fromCharCode(65+i)}. ${opt}`).join('\n') +
           `\n──────────────────\n` +
           `回复 A/B/C/D 选择答案\n` +
           `回复 N 跳过此题`;
}
```

### Step 2: 通过 mcp-sinopec 发送

```javascript
// 调用 MCP 工具发送消息
// 注意: mcp-sinopec 发送到的是"当前聚焦的石化通聊天窗口"
// 实际使用时需要:
//   1. 确认石化通目标聊天窗口已打开并聚焦
//   2. 或者预设聊天窗口（通过窗口标题定位）

const result = await task(
    category="unspecified-low",
    load_skills=["mcp-sinopec"],
    prompt=`
        使用 mcp-sinopec 向石化通发送以下消息:
        ${message}

        执行步骤:
        1. 先 sinopec_status 检查石化通是否运行
        2. 切换到正确的聊天窗口（测井培训群或个人）
        3. sinopec_send 发送消息
        4. 确认发送成功
    `
);
```

**⚠️ 当前限制**: mcp-sinopec 向"当前聚焦的石化通聊天窗口"发送消息。这就要求：
- 石化通客户端必须在登录状态
- 目标聊天窗口必须打开/可切换到
- 实际部署时需要一个专用的"机器人账号"的石化通窗口

### Step 3: 接收用户回复（轮询 OCR）

```javascript
// 通过定时 OCR 读取石化通消息窗口
// 检测是否有新的回复消息

async function pollReply(userId, timeout = 300000) { // 5分钟超时
    const startTime = Date.now();
    while (Date.now() - startTime < timeout) {
        const result = await task(
            category="unspecified-low",
            load_skills=["mcp-sinopec"],
            prompt="使用 sinopec_read 读取石化通最新消息，返回OCR识别结果"
        );
        
        // 解析 OCR 结果，提取用户回复
        const reply = parseReply(result.text);
        if (reply && isValidReply(reply)) {
            return reply;
        }
        
        await sleep(5000); // 每5秒轮询一次
    }
    return null;
}
```

### Step 4: 处理回复并反馈

```javascript
async function handleReply(userId, reply, currentItem) {
    const correctAnswer = currentItem.quiz.correctAnswer;
    const isCorrect = reply.answer === correctAnswer;
    const quality = isCorrect ? 
        (reply.confidence === 'high' ? 5 : 4) : 
        (reply.answer ? 2 : 0);

    // 更新 SRS 排期
    const next = calculateNextReview(quality, currentItem);
    await LearningProgress.findByIdAndUpdate(currentItem._id, {
        easeFactor: next.easeFactor,
        interval: next.interval,
        reviewCount: currentItem.reviewCount + 1,
        nextReviewAt: next.nextReviewAt,
        lastReviewAt: new Date(),
        lastQuality: quality,
    });

    // 构建反馈消息
    const feedback = isCorrect ? 
        buildCorrectFeedback(currentItem) : 
        buildWrongFeedback(currentItem, correctAnswer);

    // 通过石化通发送反馈
    await sendViaSinopec(feedback);
}
```

