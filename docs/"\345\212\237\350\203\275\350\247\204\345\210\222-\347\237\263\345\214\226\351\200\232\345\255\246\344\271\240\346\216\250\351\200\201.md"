## 三、后端模块设计

### 3.1 复习排期引擎（复用/扩展现有）

**文件**: `utils/srsAlgorithm.js` — SM-2 算法（约 40 行）

```javascript
function calculateNextReview(quality, previous) {
    // quality: 0(完全忘记) ~ 5(完美回答)
    const minEF = 1.3;
    let ef = previous.easeFactor || 2.5;
    ef = ef + (0.1 - (5 - quality) * (0.08 + (5 - quality) * 0.02));
    ef = Math.max(minEF, ef);

    let interval;
    if (quality < 3) interval = 1;
    else if (previous.reviewCount === 0) interval = 1;
    else if (previous.reviewCount === 1) interval = 3;
    else interval = Math.round(previous.interval * ef);

    return {
        interval: Math.min(interval, 365),
        easeFactor: Math.round(ef * 100) / 100,
        nextReviewAt: new Date(Date.now() + interval * 86400000),
    };
}
```

